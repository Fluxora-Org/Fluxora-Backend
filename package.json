{
  "name": "indexer-replay-batching",
  "version": "1.0.0",
  "description": "Contract event indexer with optimized replay batching",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "test:watch": "jest --watch",
    "dev": "ts-node src/index.ts",
    "start": "node dist/src/index.js",
    "migrate": "ts-node migrations/run.ts",
    "seed": "ts-node scripts/seed-test-data.ts",
    "benchmark": "ts-node scripts/benchmark.ts",
    "verify": "ts-node scripts/verify-setup.ts",
    "lint": "eslint src tests --ext .ts",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f indexer",
    "docker:migrate": "docker-compose exec indexer pnpm run migrate",
    "docker:seed": "docker-compose exec indexer pnpm run seed",
    "docker:test": "docker-compose exec indexer pnpm test"
  },
  "keywords": ["indexer", "blockchain", "events"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.0",
    "dotenv": "^16.3.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.3.1",
    "@types/pg": "^8.10.2",
    "@types/jest": "^29.5.2",
    "@typescript-eslint/eslint-plugin": "^5.60.0",
    "@typescript-eslint/parser": "^5.60.0",
    "axios": "^1.4.0",
    "eslint": "^8.43.0",
    "prettier": "^2.8.8",
    "typescript": "^5.1.3",
    "ts-node": "^10.9.1",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0"
  }
}
